---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';

interface Props {
  article: CollectionEntry<'articles'>;
}

const { article } = Astro.props;
const { title, description, pubDate, updatedDate, author, tags, heroImage } = article.data;

const formattedPubDate = pubDate.toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedUpdatedDate = updatedDate?.toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// 関連記事を取得（同じタグを持つ記事）
const allArticles = await getCollection('articles');
const relatedArticles = allArticles
  .filter(a => a.id !== article.id && a.data.tags.some(tag => tags.includes(tag)))
  .slice(0, 4);

// パンくずリスト用のJSON-LD
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'ホーム',
      item: new URL('/', Astro.site).toString(),
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: '記事一覧',
      item: new URL('/articles', Astro.site).toString(),
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: title,
      item: new URL(Astro.url.pathname, Astro.site).toString(),
    },
  ],
};

// Article構造化データ
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: description,
  image: new URL('/images/og-default.jpg', Astro.site).toString(),
  datePublished: pubDate.toISOString(),
  dateModified: updatedDate?.toISOString() || pubDate.toISOString(),
  author: {
    '@type': 'Organization',
    name: author,
  },
  publisher: {
    '@type': 'Organization',
    name: 'クレジットカード比較',
    logo: {
      '@type': 'ImageObject',
      url: new URL('/images/logo.png', Astro.site).toString(),
    },
  },
};
---

<BaseLayout title={title} description={description}>
  <!-- 構造化データ -->
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />

  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- パンくずリスト -->
    <nav class="text-sm text-gray-600 mb-6" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2" itemscope itemtype="https://schema.org/BreadcrumbList">
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <a href="/" itemprop="item" class="hover:text-blue-600">
            <span itemprop="name">ホーム</span>
          </a>
          <meta itemprop="position" content="1" />
        </li>
        <li class="text-gray-400">/</li>
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <a href="/articles" itemprop="item" class="hover:text-blue-600">
            <span itemprop="name">記事一覧</span>
          </a>
          <meta itemprop="position" content="2" />
        </li>
        <li class="text-gray-400">/</li>
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <span itemprop="name" class="text-gray-900" aria-current="page">{title}</span>
          <meta itemprop="position" content="3" />
        </li>
      </ol>
    </nav>

    <!-- ヒーロー画像 -->
    {heroImage && (
      <div class="relative w-full h-96 mb-8 rounded-xl overflow-hidden shadow-2xl">
        <img 
          src={heroImage} 
          alt={title}
          class="w-full h-full object-cover"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/30 to-transparent flex items-end">
          <div class="p-8 w-full">
            <h1 class="text-4xl md:text-5xl font-bold text-white mb-3 drop-shadow-lg">
              {title}
            </h1>
            <p class="text-xl text-white/90 drop-shadow-md">
              {description}
            </p>
          </div>
        </div>
      </div>
    )}

    <!-- 記事ヘッダー -->
    <header class="mb-8">
      {!heroImage && (
        <>
          <h1 class="text-4xl font-bold text-gray-900 mb-4">{title}</h1>
          <p class="text-xl text-gray-600 mb-4">{description}</p>
        </>
      )}
      
      <div class="flex items-center gap-4 text-sm text-gray-600">
        <time datetime={pubDate.toISOString()}>公開: {formattedPubDate}</time>
        {updatedDate && (
          <>
            <span>•</span>
            <time datetime={updatedDate.toISOString()}>更新: {formattedUpdatedDate}</time>
          </>
        )}
        <span>•</span>
        <span>{author}</span>
      </div>

      {tags.length > 0 && (
        <div class="flex gap-2 mt-4">
          {tags.map((tag) => (
            <span class="bg-blue-100 text-blue-800 px-3 py-1 rounded-full text-sm">
              #{tag}
            </span>
          ))}
        </div>
      )}
    </header>

    <!-- 記事本文 -->
    <div class="prose prose-lg max-w-none prose-headings:font-bold prose-h2:text-3xl prose-h2:mt-12 prose-h2:mb-6 prose-h3:text-2xl prose-h3:mt-8 prose-h3:mb-4 prose-p:text-gray-700 prose-p:leading-relaxed prose-a:text-blue-600 prose-a:no-underline hover:prose-a:underline prose-strong:text-gray-900 prose-ul:list-disc prose-ol:list-decimal">
      <slot />
    </div>

    <!-- 記事フッター -->
    <footer class="mt-16 pt-8 border-t border-gray-200">
      <div class="bg-blue-50 p-6 rounded-lg">
        <h3 class="text-lg font-semibold text-gray-900 mb-2">この記事は役に立ちましたか？</h3>
        <p class="text-gray-700 mb-4">クレジットカード選びに関するご質問やフィードバックをお待ちしています。</p>
        <div class="flex gap-4">
          <button class="bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700">
            役に立った
          </button>
          <button class="bg-gray-200 text-gray-800 px-6 py-2 rounded-lg hover:bg-gray-300">
            もっと知りたい
          </button>
        </div>
      </div>
    </footer>
  </article>

  <!-- 関連記事 -->
  {relatedArticles.length > 0 && (
    <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 border-t border-gray-200">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">関連記事</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {relatedArticles.map((relatedArticle) => (
          <a 
            href={`/articles/${relatedArticle.id.replace('.md', '')}`}
            class="block bg-white border border-gray-200 rounded-lg p-6 hover:shadow-lg transition-shadow"
          >
            <h3 class="text-lg font-semibold text-gray-900 mb-2 line-clamp-2">
              {relatedArticle.data.title}
            </h3>
            <p class="text-gray-600 text-sm mb-3 line-clamp-2">
              {relatedArticle.data.description}
            </p>
            <div class="flex gap-2 flex-wrap">
              {relatedArticle.data.tags.slice(0, 3).map((tag) => (
                <span class="bg-blue-100 text-blue-800 px-2 py-1 rounded text-xs">
                  #{tag}
                </span>
              ))}
            </div>
            <div class="mt-4 text-blue-600 text-sm font-semibold flex items-center gap-1">
              続きを読む
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}
</BaseLayout>

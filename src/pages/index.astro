// WebSite構造化データ
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'クレジットカード比較',
  description: 'マリオットボンヴォイAMEXからの切り替えをサポートする専門サイト',
  url: Astro.site?.toString(),
};

// FAQスキーマ
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'マリオットAMEXから切り替えるべきカードは？',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'JALマイル重視ならセゾンプラチナビジネス、ANAマイル重視ならアメックスゴールドプリファード、ホテル特典重視ならヒルトンAMEXがおすすめです。',
      },
    },
    {
      '@type': 'Question',
      name: 'マリオットAMEXの年会費はいくら？',
      acceptedAnswer: {
        '@type': 'Answer',
        text: '2025年8月以降、マリオットボンヴォイAMEXプレミアムの年会費は82,500円です。',
      },
    },
    {
      '@type': 'Question',
      name: 'セゾンプラチナビジネスのJALマイル還元率は？',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'SAISON MILE CLUB登録で1.125%のJALマイル還元率を実現できます。',
      },
    },
  ],
};
---

<BaseLayout 
  title="クレジットカード比較 | マリオットAMEX切り替えガイド"
  description="マリオットボンヴォイAMEXからの切り替えをサポート。セゾンプラチナビジネス、アメックスゴールドなど最適なカードを徹底比較。"
>
  <!-- 構造化データ -->
  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- ヒーローセクション（American Express風） -->
  <section class="relative bg-gradient-to-r from-[#003087] to-[#004B9D] text-white overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-24">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center">
        <!-- 左側：テキスト -->
        <div class="z-10">
          <h1 class="text-3xl lg:text-5xl font-bold mb-4 leading-tight">
            ゴールドで味わう<br />
            信頼と多彩なサービス<br />
            ワンランク上の経験を
          </h1>
          <p class="text-lg lg:text-xl text-blue-100 mb-6">
            マリオットAMEXからの切り替えをサポート。あなたに最適なゴールドカードを見つけましょう。
          </p>
        </div>
        <!-- 右側：画像 -->
        <div class="relative h-64 lg:h-96">
          <img 
            src="/images/hero-cards.png" 
            alt="クレジットカード"
            class="absolute right-0 top-0 h-full object-contain"
            onerror="this.style.display='none'"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- タブナビゲーション（American Express風） -->
  <section class="bg-white border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex overflow-x-auto space-x-2 lg:space-x-4 py-4">
        <button class="flex flex-col items-center min-w-[100px] lg:min-w-[140px] p-3 rounded-lg hover:bg-gray-50 transition">
          <span class="text-2xl mb-1">🎴</span>
          <span class="text-xs lg:text-sm font-medium text-gray-700">すべての<br />カード</span>
        </button>
        <button class="flex flex-col items-center min-w-[100px] lg:min-w-[140px] p-3 rounded-lg hover:bg-gray-50 transition">
          <span class="text-2xl mb-1">💳</span>
          <span class="text-xs lg:text-sm font-medium text-gray-700">スタンダード<br />カード</span>
        </button>
        <button class="flex flex-col items-center min-w-[100px] lg:min-w-[140px] p-3 rounded-lg bg-blue-50 border-2 border-blue-600 transition">
          <span class="text-2xl mb-1">💎</span>
          <span class="text-xs lg:text-sm font-bold text-blue-600">ゴールド<br />カード</span>
        </button>
        <button class="flex flex-col items-center min-w-[100px] lg:min-w-[140px] p-3 rounded-lg hover:bg-gray-50 transition">
          <span class="text-2xl mb-1">👑</span>
          <span class="text-xs lg:text-sm font-medium text-gray-700">プレミアム<br />カード</span>
        </button>
        <button class="flex flex-col items-center min-w-[100px] lg:min-w-[140px] p-3 rounded-lg hover:bg-gray-50 transition">
          <span class="text-2xl mb-1">💼</span>
          <span class="text-xs lg:text-sm font-medium text-gray-700">ビジネス<br />カード</span>
        </button>
        <button class="flex flex-col items-center min-w-[100px] lg:min-w-[140px] p-3 rounded-lg hover:bg-gray-50 transition">
          <span class="text-2xl mb-1">✈️</span>
          <span class="text-xs lg:text-sm font-medium text-gray-700">航空会社<br />提携カード</span>
        </button>
        <button class="flex flex-col items-center min-w-[100px] lg:min-w-[140px] p-3 rounded-lg hover:bg-gray-50 transition">
          <span class="text-2xl mb-1">🏨</span>
          <span class="text-xs lg:text-sm font-medium text-gray-700">ホテル<br />提携カード</span>
        </button>
      </div>
    </div>
  </section>

  <!-- カード一覧（American Express風：縦1列レイアウト） -->
  <section class="bg-gray-50 py-12">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-lg text-gray-700 mb-8">{cards.length} 枚のカードがあなたの選択に一致します</p>
      
      <div class="space-y-8">
        {cards.map((card) => (
          <div class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-xl transition">
            {card.badge && (
              <div class="bg-yellow-400 text-gray-900 px-4 py-2 text-sm font-semibold">
                {card.badge}
              </div>
            )}
            <div class="p-6 lg:p-8">
              <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                <!-- 左：カード画像 -->
                <div class="lg:col-span-1 flex flex-col items-center lg:items-start">
                  <div class="w-64 h-40 bg-gradient-to-br from-gray-800 to-gray-600 rounded-lg shadow-lg mb-4 flex items-center justify-center">
                    <img 
                      src={card.image} 
                      alt={card.name}
                      class="w-full h-full object-cover rounded-lg"
                      onerror="this.style.display='none'; this.parentElement.innerHTML='<span class=text-white text-sm>カード画像</span>'"
                    />
                  </div>
                  <a 
                    href={`/cards/${card.id}`} 
                    class="text-blue-600 font-semibold hover:underline mb-2 text-center lg:text-left"
                  >
                    詳しくはこちら →
                  </a>
                  <button class="w-full bg-blue-600 text-white px-6 py-2 rounded font-semibold hover:bg-blue-700 transition">
                    他のカードと比較する
                  </button>
                </div>

                <!-- 右：カード詳細 -->
                <div class="lg:col-span-2">
                  <h3 class="text-xl lg:text-2xl font-bold text-gray-900 mb-3">
                    {card.name}
                  </h3>
                  <div class="text-sm text-gray-700 mb-4 space-y-1">
                    <p>{card.annualFee}</p>
                    <p>{card.familyCard}</p>
                  </div>
                  
                  {card.bonus && (
                    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mb-4">
                      <p class="text-xs text-blue-700 font-semibold mb-1">ご入会特典</p>
                      <p class="text-lg font-bold text-blue-900 mb-1">{card.bonus}</p>
                      <p class="text-xs text-gray-600">{card.bonusDetail}</p>
                    </div>
                  )}

                  <!-- カードの特長 -->
                  <div class="mt-6">
                    <p class="text-sm font-semibold text-gray-700 mb-3">カードの特長</p>
                    <ul class="space-y-3">
                      {card.features.map((feature) => (
                        <li class="flex items-start">
                          <span class="text-2xl mr-3 flex-shrink-0">{feature.icon}</span>
                          <span class="text-sm text-gray-700 pt-1">{feature.text}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 最新記事セクション -->
  {latestArticles.length > 0 && (
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <h2 class="text-3xl font-bold text-gray-900 mb-8">📰 最新記事</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {latestArticles.map((article) => (
          <a href={`/articles/${article.slug}`} class="group">
            <article class="bg-white rounded-lg shadow hover:shadow-lg transition">
              <div class="p-6">
                <time class="text-sm text-gray-600" datetime={article.data.pubDate.toISOString()}>
                  {article.data.pubDate.toLocaleDateString('ja-JP')}
                </time>
                <h3 class="text-lg font-bold text-gray-900 mt-2 mb-2 group-hover:text-blue-600 transition">
                  {article.data.title}
                </h3>
                <p class="text-gray-600 text-sm line-clamp-3">
                  {article.data.description}
                </p>
              </div>
            </article>
          </a>
        ))}
      </div>
      
      <div class="text-center mt-8">
        <a href="/articles" class="inline-block bg-blue-600 text-white px-8 py-3 rounded-lg font-semibold hover:bg-blue-700 transition">
          記事一覧を見る
        </a>
      </div>
    </section>
  )}

  <!-- CTAセクション -->
  <section class="bg-gradient-to-r from-[#003087] to-[#004B9D] text-white py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold mb-4">
        💡 あなたに最適なカードを見つけよう
      </h2>
      <p class="text-xl text-blue-100 mb-8">
        年間決済額を入力するだけで、実質コストを自動計算。最適なカードを診断します。
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a href="/simulator" class="inline-block bg-yellow-400 text-gray-900 px-10 py-4 rounded-lg font-bold text-lg hover:bg-yellow-300 transition shadow-lg">
          💳 診断ツールを使う（無料）
        </a>
        <a href="/cards/comparison" class="inline-block bg-white text-blue-600 px-10 py-4 rounded-lg font-bold text-lg hover:bg-blue-50 transition">
          📊 カード比較表を見る
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

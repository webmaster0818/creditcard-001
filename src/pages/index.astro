    bonus: '合計5,000マイル獲得可能',
    bonusDetail: 'ご入会ボーナスマイルとファーストフライトボーナスマイルで合計5,000マイル獲得可能',
    features: [
      { icon: '✈️', text: 'JALマイル還元率1.0%' },
      { icon: '🏨', text: 'プライオリティ・パス無料' },

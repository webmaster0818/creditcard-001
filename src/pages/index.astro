  },
  {
    id: 'hilton-honors-amex',
    name: 'ヒルトン・オナーズ アメリカン・エキスプレス®・カード',
    badge: '',
    annualFee: '年会費16,500円（税込）',
    familyCard: '家族カード1枚目無料、2枚目以降6,600円（税込）',
    bonus: 'ヒルトン・オナーズ・ゴールドステータス無条件付与',
    bonusDetail: 'ヒルトン・オナーズ・ゴールドステータスを無条件でご提供',
    features: [
      { icon: '🏨', text: 'カード利用と継続でウィークエンド無料宿泊プレゼント' },
      { icon: '⭐', text: 'ヒルトン・オナーズ・ゴールドステータスを無条件でご提供' },
      { icon: '💎', text: 'カードご利用100円につき最大3ポイント貯まる' },
    ],
    image: '/images/hilton-honors-amex.png',
  },
  {
    id: 'ana-amex-gold',
    name: 'ANA アメリカン・エキスプレス®・ゴールド・カード',
    badge: '期間限定ご入会特典',
    annualFee: '年会費34,100円（税込）',
    familyCard: '家族カード17,050円（税込）',
    bonus: '合計100,000マイル相当獲得可能',
    bonusDetail: '【2026年4月14日（火）お申し込み分まで】',
    features: [
      { icon: '♾️', text: 'ポイントの有効期間は無期限' },
      { icon: '✈️', text: 'ANAグループでのカードご利用はポイント2倍' },
      { icon: '🎁', text: '毎年のカード継続毎に2,000マイルプレゼント' },
    ],
    image: '/images/ana-amex-gold.png',
  },
  {
    id: 'marriott-bonvoy-amex',
    name: 'Marriott Bonvoy® アメリカン・エキスプレス®・プレミアム・カード',
    badge: '期間限定ご入会特典',
    annualFee: '年会費82,500 円（税込）',
